{
  "t": "screen",
  "p": {
    "_k": "screen",
    "id": "screen",
    "subtitle": {
      "v": "Library"
    },
    "title": {
      "b": "screen.title"
    }
  },
  "c": [
    {
      "t": "section",
      "p": {
        "_k": "hero",
        "desc": {
          "v": "Featured today"
        },
        "title": {
          "b": "hero.title"
        }
      },
      "c": [
        {
          "t": "text",
          "p": {
            "_k": "hero-text",
            "content": {
              "b": "hero.subtitle"
            },
            "em": "strong",
            "role": "subtitle",
            "tone": "info",
            "tr": true
          }
        },
        {
          "t": "pressable",
          "p": {
            "_k": "hero-open",
            "act": {
              "p": {
                "to": "details"
              },
              "t": "navigate"
            },
            "label": {
              "v": "Open"
            }
          },
          "c": [
            {
              "t": "text",
              "p": {
                "_k": "hero-open-text",
                "content": {
                  "v": "Open details"
                },
                "em": "normal",
                "role": "body"
              }
            }
          ]
        }
      ]
    },
    {
      "t": "grid",
      "p": {
        "_k": "gallery",
        "cols": {
          "b": 2,
          "m": 4
        },
        "cont": {
          "k": "remote",
          "label": {
            "v": "More"
          },
          "load": {
            "t": "loadmore"
          },
          "loading": {
            "b": "gallery.loading_label"
          },
          "more": true
        },
        "gap": "lg"
      },
      "c": [
        {
          "t": "badge",
          "p": {
            "_k": "featured-badge",
            "label": {
              "v": "Featured"
            },
            "tone": "success"
          }
        },
        {
          "t": "media",
          "p": {
            "_k": "cover",
            "alt": "Cover image",
            "ar": "poster",
            "exp": true,
            "kind": "cover",
            "ref": {
              "name": "cover-art",
              "type": "asset"
            }
          }
        }
      ]
    },
    {
      "t": "list",
      "p": {
        "_k": "chapters",
        "cont": {
          "bind": "chapters.visible",
          "init": 10,
          "k": "inc",
          "label": {
            "b": "chapters.more_label"
          },
          "step": 10
        },
        "density": "normal"
      },
      "c": [
        {
          "t": "item",
          "p": {
            "_k": "chapter-1",
            "id": "chapter-1"
          },
          "c": [
            {
              "t": "leading",
              "c": [
                {
                  "t": "icon",
                  "p": {
                    "_k": "chapter-icon",
                    "label": "Chapter",
                    "name": "book",
                    "tone": "muted"
                  }
                }
              ]
            },
            {
              "t": "primary",
              "c": [
                {
                  "t": "text",
                  "p": {
                    "_k": "chapter-title",
                    "content": {
                      "b": "chapter.title"
                    },
                    "em": "normal",
                    "role": "body"
                  }
                }
              ]
            },
            {
              "t": "trailing",
              "c": [
                {
                  "t": "value",
                  "p": {
                    "_k": "chapter-pages",
                    "fmt": "number",
                    "role": "caption",
                    "tone": "muted",
                    "value": {
                      "b": "chapter.pages"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "t": "disclosure",
      "p": {
        "_k": "filters",
        "bind": "ui.filters_open",
        "label": {
          "v": "Filters"
        },
        "labelExp": {
          "b": "ui.filters_expanded_label"
        }
      },
      "c": [
        {
          "t": "form",
          "p": {
            "_k": "search-form",
            "name": "search",
            "submit": {
              "t": "submit"
            }
          },
          "c": [
            {
              "t": "input",
              "p": {
                "_k": "query",
                "dis": {
                  "b": "filters.disabled"
                },
                "help": {
                  "b": "filters.help"
                },
                "kind": "text",
                "label": {
                  "v": "Query"
                },
                "name": "query",
                "ph": {
                  "v": "Type to search"
                },
                "req": false,
                "value": {
                  "b": "filters.query"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "t": "menu",
      "p": {
        "_k": "sort-menu",
        "align": "start",
        "intent": "primary",
        "label": {
          "v": "Sort"
        }
      },
      "c": [
        {
          "t": "menu-item",
          "p": {
            "do": {
              "p": {
                "sort": "recent"
              },
              "t": "navigate"
            },
            "id": "recent",
            "label": {
              "v": "Recent"
            },
            "sel": true
          }
        },
        {
          "t": "menu-item",
          "p": {
            "dis": {
              "b": "menu.popular_disabled"
            },
            "do": {
              "p": {
                "sort": "popular"
              },
              "t": "navigate"
            },
            "id": "popular",
            "label": {
              "b": "menu.popular_label"
            },
            "sel": false
          }
        }
      ]
    },
    {
      "t": "if",
      "p": {
        "_k": "upsell",
        "if": {
          "b": "flags.show_upsell"
        }
      },
      "c": [
        {
          "t": "status",
          "p": {
            "_k": "promo-status",
            "msg": {
              "b": "promo.message"
            },
            "severity": "info",
            "title": {
              "v": "Promo"
            }
          },
          "c": [
            {
              "t": "action",
              "p": {
                "_k": "promo-cta",
                "dis": {
                  "b": "promo.disabled"
                },
                "do": {
                  "t": "navigate"
                },
                "icon": "sparkles",
                "intent": "primary",
                "label": {
                  "v": "View"
                },
                "variant": "button"
              }
            }
          ]
        },
        {
          "t": "empty",
          "p": {
            "_k": "promo-empty",
            "icon": "sparkles",
            "msg": {
              "v": "Come back soon"
            },
            "title": {
              "v": "Nothing yet"
            }
          }
        }
      ]
    },
    {
      "t": "slot",
      "p": {
        "_k": "footer-slot",
        "name": "footer"
      },
      "c": [
        {
          "t": "loading",
          "p": {
            "_k": "footer-loading",
            "label": {
              "b": "footer.label"
            },
            "progress": {
              "b": "footer.progress"
            }
          }
        }
      ]
    }
  ]
}
