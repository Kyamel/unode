{
  "name": "unode-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint --fix",
    "check": "pnpm typecheck && pnpm lint",
    "dev": "pnpm --filter website dev",
    "dev:web-react": "pnpm --filter web-react dev",
    "dev:web-svelte": "pnpm --filter web-svelte dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.64.0"
  }
}
