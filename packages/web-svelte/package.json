{
  "name": "unode-svelte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Svelte adapter package for Unode web renderers.",
  "scripts": {
    "build:wasm": "./build.sh",
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "unode-core": "workspace:*",
    "unode-renderer": "workspace:*",
    "svelte": "^5.7.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
