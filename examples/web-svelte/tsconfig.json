{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "unode-web-core": ["../../packages/unode-web-core/src"],
      "unode-web-renderer": ["../../packages/unode-web-renderer/src"],
      "unode-svelte": ["../../packages/unode-svelte/src"]
    }
  },
  "include": [
    "demo/**/*.ts",
    "demo/**/*.svelte",
    "vite.config.ts",
    "svelte.config.js"
  ]
}
