{
  "name": "web-svelte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Svelte demo app for the Unode web runtime.",
  "scripts": {
    "build:wasm": "./build.sh",
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "smoke": "node scripts/smoke.mjs",
    "lint": "eslint demo scripts vite.config.ts svelte.config.js"
  },
  "dependencies": {
    "unode-core": "workspace:*",
    "unode-svelte": "workspace:*",
    "svelte": "^5.7.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
